{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lightbridge": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LightBridge Server",
      "options": {
        "baseURL": "{env:LIGHTBRIDGE_BASE_URL}",
        "headers": {
          "Authorization": "Bearer {env:LIGHTBRIDGE_API_KEY}"
        }
      },
      "models": {
        "gemini-3-flash": {
          "name": "Gemini 3 Flash",
          "limit": {
            "context": 996147,
            "output": 62259
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "limit": {
            "context": 200000,
            "output": 72600
          },
          "cost": {
            "input": 1,
            "output": 3.2,
            "cache_read": 0.2
          }
        },
        "gemini-3.1-flash-lite": {
          "name": "Gemini 3.1 Flash Lite",
          "limit": {
            "context": 950000,
            "output": 60800
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "limit": {
            "context": 260000,
            "output": 32000
          },
          "cost": {
            "input": 0.6,
            "output": 3.0,
            "cache_read": 0.1
          }
        }
      }
    }
  },
  "agent": {
    "moa-orchestrator": {
      "description": "Coordinates research, selection, TDD planning, implementation, and resumable execution across the MoA workflow.",
      "mode": "primary",
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-orchestrator.txt}",
      "temperature": 0.2,
      "permission": {
        "task": {
          "*": "deny",
          "moa-*": "allow"
        }
      }
    },

    "moa-ideation": {
      "description": "Generates a few high-quality strategic paths.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-ideation.txt}",
      "temperature": 0.7
    },

    "moa-brainstorming": {
      "description": "Explores many solution variants and unconventional options.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-brainstorming.txt}",
      "top_p": 0.9,
      "temperature": 0.95
    },

    "moa-rejection": {
      "description": "Finds fatal flaws, worst-case scenarios, kill criteria, and structural failure signals from test findings.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-rejection.txt}",
      "temperature": 0.1
    },

    "moa-constraint-research": {
      "description": "Researches technical, runtime, vendor, and compliance constraints.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-constraint-research.txt}",
      "temperature": 0.2
    },

    "moa-security": {
      "description": "Threat-models proposals and defines mandatory controls.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/glm-5",
      "prompt": "{file:./prompts/moa-security.txt}",
      "temperature": 0.1
    },

    "moa-tdd": {
      "description": "Creates a strict test-first phased execution plan and canonical resumable todo list.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/kimi-k2.5",
      "prompt": "{file:./prompts/moa-tdd.txt}",
      "temperature": 0.1
    },

    "moa-implementer": {
      "description": "Executes the canonical phased plan one slice at a time and updates resumable execution state.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/kimi-k2.5",
      "prompt": "{file:./prompts/moa-implementer.txt}",
      "temperature": 0.1
    },

    "moa-test-triage-lite": {
      "description": "Runs predefined validation commands and cheaply classifies failures into actionable findings.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/gemini-3.1-flash-lite",
      "prompt": "{file:./prompts/moa-test-triage-lite.txt}",
      "temperature": 0.1
    },

    "moa-quick-scout": {
      "description": "Handles tiny investigations and very easy low-risk tasks cheaply.",
      "mode": "subagent",
      "hidden": true,
      "model": "lightbridge/gemini-3.1-flash-lite",
      "prompt": "{file:./prompts/moa-quick-scout.txt}",
      "temperature": 0.1
    }
  }
}
