EXPO_PUBLIC_BACKEND_URL=https://localhost:13000
EXPO_PUBLIC_USAGE_URL=https://localhost:13002

EXPO_PUBLIC_KEYCLOAK_ISSUER=http://keycloak:9100/realms/dev
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=test-client
EXPO_PUBLIC_KEYCLOAK_SCHEME=self-service

# JWT Audience Validation
# Expected audience(s) for JWT token validation (comma-separated for multiple audiences)
# The token's 'aud' claim must contain at least one of these values
EXPO_PUBLIC_KEYCLOAK_EXPECTED_AUDIENCE=lightbridge-api-key,converse-frontend,lightbridge-token-issuer

# Set to 'false' to allow tokens without audience claim (not recommended for production)
EXPO_PUBLIC_KEYCLOAK_AUDIENCE_REQUIRED=true

